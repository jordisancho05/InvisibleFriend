# Variables de entorno para Invisible Friend
# Copia este archivo a .env en la raíz del proyecto y rellena con tus valores:
#   cp .env.example .env
# .env NO se versiona: contiene credenciales reales.

# Email del remitente (debe ser una cuenta de Gmail)
MAILSENDER=tu_email@gmail.com

# Contraseña de APLICACIÓN de esa cuenta, no la contraseña normal.
# Se genera en https://myaccount.google.com/apppasswords
# (requiere tener activada la verificación en dos pasos).
PASSWORD=tu_contraseña_de_aplicacion
