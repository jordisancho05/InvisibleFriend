# Environment variables for Invisible Friend
# Copy this file to .env at the project root and fill it in with your values:
#   cp .env.example .env
# .env is NOT versioned: it contains real credentials.

# Sender email (must be a Gmail account)
MAILSENDER=your_email@gmail.com

# APP password for that account, not the regular password.
# Generated at https://myaccount.google.com/apppasswords
# (requires two-step verification enabled).
PASSWORD=your_app_password
